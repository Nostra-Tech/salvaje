rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/profile/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /coaches/{coachId}/profile/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == coachId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /payment_receipts/{userId}/{filename} {
      allow read: if request.auth.uid == userId
        || (request.auth != null &&
            exists(/databases/(default)/documents/admins/$(request.auth.uid)));
      allow write: if request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|pdf)');
    }
  }
}
